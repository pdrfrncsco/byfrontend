{
  "name": "bolayetu-frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Enterprise-grade football ecosystem platform frontend",
  "author": "BolaYetu Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
